<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_partner_form_transport_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.transport.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="DATOS DE TRANSPORTE" name="transport_data">
                    <group>
                        <group string="Información General">
                            <field name="transport_company"/>
                            <field name="transport_cuit"/>
                            <field name="transport_driver"/>
                        </group>
                        <group string="Vehículo">
                            <field name="chassis_plate"/>
                            <field name="trailer_plate"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    
</odoo>